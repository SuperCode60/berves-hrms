{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://berves-hrms-production.up.railway.app/api/$1"
    },
    {
      "src": "^/(.*)\\.(.*)$",
      "dest": "/$1.$2"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://berves-hrms-production.up.railway.app/api/v1"
  }
}
# --- Browser → Laravel (skip Vite proxy) ---
# Full API base including /api/v1. If unset, axios uses /api/v1 and Vite proxies /api below.
# VITE_API_URL=http://127.0.0.1:8000/api/v1

# --- Dev server: proxy /api/* to Laravel (used when VITE_API_URL is unset) ---
# Point this at the same host/port where `php artisan serve` runs for berves-backend.
# If another app already uses 8000, use e.g. 8001: `php artisan serve --port=8001`
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8001

# Dev server + HMR (fix WebSocket failed / connection lost: same host as the URL bar, fixed port).
# VITE_DEV_SERVER_PORT=3000
# VITE_DEV_SERVER_HOST=localhost
# Set to false only if you want Vite to pick another port when this one is busy (HMR may break until refresh).
# VITE_DEV_SERVER_STRICT_PORT=false

# Berves HRMS Production Environment Configuration
# Copy this file to .env and update with your production values

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=your-production-db-host
DB_PORT=3306
DB_DATABASE=berves_hrms
DB_USERNAME=your_db_user
DB_PASSWORD=your_secure_db_password

# Redis Configuration
REDIS_HOST=your-production-redis-host
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# Cache Configuration
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Laravel Application
APP_NAME="Berves HRMS"
APP_ENV=production
APP_KEY=base64:your-32-character-random-key-here
APP_DEBUG=false
APP_URL=https://hrms.yourdomain.com

# Frontend Configuration
FRONTEND_URL=https://your-frontend-domain.com

# Laravel Sanctum
SANCTUM_STATEFUL_DOMAINS=hrms.yourdomain.com,your-frontend-domain.com
SANCTUM_TOKEN_EXPIRATION=43200

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Backup Configuration
BACKUP_DISK=s3
BACKUP_NOTIFICATION_EMAIL=admin@yourdomain.com

# Frontend Configuration (for reference)
VITE_API_URL=https://hrms.yourdomain.com/api/v1

# Security Configuration
FORCE_HTTPS=true

# Logging Configuration
LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

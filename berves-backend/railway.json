{
  "build": {
    "builder": "nixpacks",
    "buildCommand": "composer install --no-dev --optimize-autoloader --no-interaction"
  },
  "deploy": {
    "preDeployCommand": "php artisan migrate --force",
    "startCommand": "php artisan serve --host=0.0.0.0 --port=8080",
    "healthcheckPath": "/up",
    "restartPolicyType": "ON_FAILURE",
    "timeout": 900
  }
}